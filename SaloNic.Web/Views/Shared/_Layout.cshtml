<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SaloNic organiza reservas de salones para eventos con una experiencia sobria, clara y profesional." />
    <title>@ViewData["Title"] - SaloNic</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SaloNic.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="navbar navbar-expand-md site-nav" aria-label="Navegacion principal">
            <div class="container">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">SaloNic</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavigation" aria-controls="mainNavigation"
                        aria-expanded="false" aria-label="Abrir navegacion">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="mainNavigation" class="navbar-collapse collapse justify-content-end">
                    <ul class="navbar-nav align-items-md-center">
                        <li class="nav-item">
                            <a class="nav-link" href="#salones">Salones</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#experiencia">Confianza</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-action" href="#reserva">Solicitar reserva</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <span>&copy; 2026 SaloNic</span>
            <span>Reservacion de salones con criterio y orden.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
